    "typescript"
  ],
  "license": "MIT",
  "private": false,
  "scripts": {
    "format": "biome format --write .",
    "test": "bun test ./example/self-process.integration.ts",
    "test:wow64": "bun test ./example/wow64.integration.ts"
  },
  "type": "module",
  "dependencies": {
    "@bun-win32/kernel32": "2.0.1"
  }
